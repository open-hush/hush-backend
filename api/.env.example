# --- Database ------------------------------------------------------------
# Postgres connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://hush:hush@localhost:5432/hush

# --- Auth (user JWT) -----------------------------------------------------
# HS256 symmetric secret. Generate with: openssl rand -base64 64
# Must be at least 32 characters.
JWT_SIGNING_KEY=replace-me-with-a-real-secret-at-least-32-chars
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000   # 30 days

# On a fresh install (empty `users` table) the API seeds one admin account.
# There is no default password. Either:
#   - set BOOTSTRAP_ADMIN_PASSWORD here (used verbatim, never written anywhere), or
#   - leave it unset and a random password is written once to a 0600 file
#     (BOOTSTRAP_ADMIN_PASSWORD_FILE, default ./initial-admin-password.txt).
# Either way: log in, change it from the dashboard, then delete the file.
BOOTSTRAP_ADMIN_EMAIL=admin@hush.local
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_PASSWORD_FILE=initial-admin-password.txt

# --- Auth (device HMAC) --------------------------------------------------
# Tolerance in seconds for the `ts` value carried in the HMAC header.
HMAC_CLOCK_SKEW_SEC=300

# --- Object storage (S3 / MinIO / R2) -----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hush-audio
S3_ACCESS_KEY=hushminio
S3_SECRET_KEY=hushminio
# Set to true when targeting a real S3 bucket (path-style off, virtual-hosted on).
S3_USE_PATH_STYLE=true

# --- API server ---------------------------------------------------------
HUSH_HOST=0.0.0.0
HUSH_PORT=8080
# Fastify logger level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# --- Device sync --------------------------------------------------------
# TTL for presigned download URLs returned by GET /v1/device/sync.
# Devices poll every ~10 min by default, so 30 min gives generous buffer.
SYNC_PRESIGN_TTL_SEC=1800

# --- Transcoding --------------------------------------------------------
# Max parallel ffmpeg processes inside the API.
TRANSCODE_CONCURRENCY=2
# Optional overrides; defaults look up `ffmpeg` / `ffprobe` on PATH.
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

# --- Observability ------------------------------------------------------
# /metrics is exposed by fastify-metrics. Set to "false" to skip (useful in
# tests so prom-client doesn't double-register global counters).
METRICS_ENABLED=true
# Per-dependency timeout for /v1/ready probes (database, object storage).
READY_PROBE_TIMEOUT_MS=2000

# --- Firmware OTA -------------------------------------------------------
# TTL for presigned download URLs returned by GET /v1/firmware/latest.
FIRMWARE_PRESIGN_TTL_SEC=1800

# --- CORS / browser clients --------------------------------------------
# Comma-separated list of origins allowed to call the API with credentials.
# Dashboard dev server runs on :3000 by default.
CORS_ALLOWED_ORIGINS=http://localhost:3000
