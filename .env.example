# --- Database ------------------------------------------------------------
# Connection string read by sqlx. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://hush:hush@localhost:5432/hush

# --- Auth (user JWT) -----------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SIGNING_KEY=replace-me-with-a-real-secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000   # 30 days

# --- Object storage (S3 / MinIO / R2) -----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hush-audio
S3_ACCESS_KEY=hushminio
S3_SECRET_KEY=hushminio
# Set to true when targeting a real S3 bucket (path-style off, virtual-hosted on).
S3_USE_PATH_STYLE=true

# --- API server ---------------------------------------------------------
HUSH_BIND=0.0.0.0:8080
RUST_LOG=info,hush_api=debug,sqlx=warn,tower_http=info

# --- Dashboard (Next.js) ------------------------------------------------
# Used by the dashboard at build/dev time to call the API.
NEXT_PUBLIC_API_URL=http://localhost:8080
