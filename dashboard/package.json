{
  "name": "hush-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Hush dashboard (Next.js 15 + TypeScript + Tailwind).",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "gen:api": "openapi-typescript ../../hush-protocol/hush-api.yaml --output lib/api/schema.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-toast": "1.2.16",
    "@tanstack/react-query": "5.101.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.453.0",
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "tailwind-merge": "2.6.1",
    "tailwindcss-animate": "1.0.7",
    "zod": "3.25.76",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.19",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
